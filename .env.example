# DataAI_Amity — environment configuration template
#
# Copy to `.env` and edit. All settings have sensible defaults so a fresh
# clone runs with zero edits IF Ollama is installed locally (see README).
#
# Real keys NEVER go in .env.example. Placeholders only.
# .env is gitignored.

# ----- Server / data scale -------------------------------------------------
APP_PORT=8000
SEED_ROWS=18000
SEED_CUSTOMERS=1200
SEED_PRODUCTS=80
SEED_STORES=24
SEED_OLTP=6000
SEED_BANKING=5000
SEED_TELECOM=7500

# Act 9 (CFO Finance Lab) data scale
SEED_FINANCE_MONTHS=12
SEED_FINANCE_EMPLOYEES=30
SEED_FINANCE_VENDORS=20

# ----- LLM / AI configuration ---------------------------------------------
# One client speaks the OpenAI-compatible Chat Completions API.
# Change LLM_PROVIDER + LLM_BASE_URL + LLM_MODEL + LLM_API_KEY to swap
# providers. Default is local Ollama so a fresh clone works offline.

# Provider: ollama | openai | azure | openrouter | nvidia
LLM_PROVIDER=ollama

# OpenAI-compatible base URL.
# Ollama exposes /v1 for compatibility.
LLM_BASE_URL=http://localhost:11434/v1

# Model id (provider-specific).
# Tested small models for Ollama (fit in <2 GB RAM — pick the smallest that works):
#   qwen2.5-coder:1.5b   (~1.0 GB, code-tuned, best for SQL — DEFAULT)
#   llama3.2:1b          (~1.3 GB, general-purpose fallback)
#   gemma2:2b            (~1.7 GB, more capable, needs ~3 GB free RAM)
#   llama3.1:8b          (~5 GB, much better quality, needs ~8 GB free RAM)
LLM_MODEL=qwen2.5-coder:1.5b

# API key. For Ollama any non-empty placeholder works.
LLM_API_KEY=ollama

# Hard timeout per LLM call (seconds).
LLM_TIMEOUT_SECONDS=30

# Sampling temperature. Keep low for SQL generation.
LLM_TEMPERATURE=0.1

# ----- Provider-specific (uncomment + fill the block you need) ------------

# --- OpenRouter ---
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct
# LLM_API_KEY=sk-or-...

# --- Azure OpenAI (uses deployment name as model) ---
# LLM_PROVIDER=azure
# LLM_BASE_URL=https://YOUR-RESOURCE.openai.azure.com
# LLM_MODEL=gpt-4o-mini
# LLM_AZURE_DEPLOYMENT=my-gpt4o-mini
# LLM_AZURE_API_VERSION=2024-08-01-preview
# LLM_API_KEY=...

# --- NVIDIA NIM ---
# LLM_PROVIDER=nvidia
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=meta/llama-3.1-8b-instruct
# LLM_API_KEY=nvapi-...

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
