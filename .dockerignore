# ----- VCS / metadata -------------------------------------------------
.git
.gitignore
.gitattributes
.github/
.dockerignore
docker-compose.yml
docker-compose.*.yml
railway.json

# ----- Secrets (NEVER bake into images) -------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
.envrc

# ----- Python build / cache artefacts ---------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
*.egg-info/
build/
.eggs/
.ipynb_checkpoints/
pip-log.txt
pip-delete-this-directory.txt
.python-version

# ----- Node / Vite ----------------------------------------------------
# node_modules is rebuilt inside the multi-stage build.
# dist is rebuilt by `npm run build` in the frontend stage.
app/frontend/node_modules/
app/frontend/dist/
app/frontend/.vite/
app/frontend/.cache/
**/node_modules/
**/.vite/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ----- Local DB / Ollama models (bind-mounted at runtime) -------------
app/backend/data/
data/
.ollama/
ollama_models/

# ----- Dev-only artefacts not needed at runtime -----------------------
app/tests/
notebooks/
docs/
scripts/
README.md
CLAUDE.md
LICENSE.md
CONTRIBUTING.md
CHANGELOG.md

# ----- Editors / IDE / OS junk ----------------------------------------
.vscode/
.idea/
*.iml
*.swp
*.swo
.history/
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- Office / temp lockfiles ----------------------------------------
~$*
*~
*.tmp
*.bak
*.orig

# ----- Misc tarballs that shouldn't be in build context ---------------
*.tar
*.tar.gz
*.zip
